<Window x:Class="MacroscopTestWork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MacroscopTestWork" xmlns:viewmodels="clr-namespace:MacroscopTestWork.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Тестовое задание Macroscop (загрузчик изображений)" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding ImageItems}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="4*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="LightGray" CornerRadius="4">
                            <Image Source="{Binding Image}" Stretch="Uniform" />
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Margin="5,0" VerticalContentAlignment="Center" />
                        <Button Grid.Column="2" Content="{Binding ButtonText}" Width="90" Command="{Binding ToggleCommand}" Margin="5,0" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="1" Content="Загрузить все" Command="{Binding LoadAllCommand}" 
                HorizontalAlignment="Center" Padding="25,8" Margin="0,15" FontSize="14" />

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="Активные загрузки:" HorizontalAlignment="Center" Margin="0,0,0,5" />
            <ProgressBar Maximum="{Binding ImageItems.Count}" Value="{Binding ActiveDownloads, Mode=OneWay}" Height="20" />
        </StackPanel>
    </Grid>
</Window>
